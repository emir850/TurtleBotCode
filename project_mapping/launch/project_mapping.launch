<launch>
  <!-- Arguments -->
  <!-- Define arguments with default values for flexibility -->
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="configuration_basename" default="turtlebot3_lds_2d.lua"/>
  <arg name="open_rviz" default="true"/>
  <arg name="slam_methods" default="gmapping"/>
  <arg name="x_pos" default="0.1"/>
  <arg name="y_pos" default="0.3"/>
  <arg name="z_pos" default="0.05"/>
  <arg name="set_base_frame" default="base_footprint"/>
  <arg name="set_odom_frame" default="odom"/>
  <arg name="set_map_frame"  default="map"/>

  <!-- Launch an empty Gazebo world -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <!-- Specify the world file to be loaded -->
    <arg name="world_name" value="$(find realrobotlab)/worlds/cafe_world.world"/>
    <!-- Set simulation parameters -->
    <arg name="paused" value="false"/>
    <arg name="use_sim_time" value="true"/>
    <arg name="gui" value="true"/>
    <arg name="headless" value="false"/>
    <arg name="debug" value="false"/>
    <arg name="verbose" value="true"/>
  </include>

  <!-- Load robot description -->
  <param name="robot_description" command="$(find xacro)/xacro --inorder $(find turtlebot3_description)/urdf/turtlebot3_$(arg model).urdf.xacro" />

  <!-- Spawn the robot model in Gazebo -->
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf" args="-urdf -model turtlebot3_$(arg model) -x $(arg x_pos) -y $(arg y_pos) -z $(arg z_pos) -param robot_description" />

  <!-- TurtleBot3 -->
  <!-- Launch the turtlebot3_bringup package for TurtleBot3 -->
  <include file="$(find turtlebot3_bringup)/launch/turtlebot3_remote.launch">
    <!-- Pass the specified robot model as an argument -->
    <arg name="model" value="$(arg model)" />
  </include>

  <!-- Gmapping -->
  <!-- Run gmapping for SLAM -->
  <node pkg="gmapping" type="slam_gmapping" name="turtlebot3_slam_gmapping" output="screen">
    <!-- Set the base, odometry, and map frames -->
    <param name="base_frame" value="$(arg set_base_frame)"/>
    <param name="odom_frame" value="$(arg set_odom_frame)"/>
    <param name="map_frame"  value="$(arg set_map_frame)"/>
    <!-- Load the project_mapping parameters from file. This file also created by us -->
    <rosparam command="load" file="$(find project_mapping)/param/project_mapping_params.yaml" />
  </node>

  <!-- rviz -->
  <group if="$(arg open_rviz)">
    <!-- Launch RViz visualization tool -->
    <node pkg="rviz" type="rviz" name="rviz" required="true"
          args="-d $(find project_mapping)/rviz/project_mapping_rviz.rviz"/>
  </group>

  <node name="record"  pkg="rosbag" type="record" args="record -O $(find project_mapping)/map/project_mapping_map.bag /tf /tf_static /turtlebot3_slam_gmapping/entropy /odom /map_updates /map_metadata /map /joint_states /initialpose /imu" />

</launch>
